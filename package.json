    "lint": "npm run lint:py && npm run lint:js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "eslint": "^10.0.2",
    "globals": "^17.3.0"
  }
}
