{
  "name": "rba-hawko-meter",
  "version": "1.0.0",
  "private": true,
  "description": "RBA Hawk-O-Meter — Interest Rate Dashboard",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "lint:py": "ruff check pipeline/ tests/",
